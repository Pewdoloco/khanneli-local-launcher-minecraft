<Window x:Class="VanillaLauncher.Client.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VanillaLauncher.Client.UI"
        mc:Ignorable="d"
        Title="VanillaLauncher — Настройки" Height="720" Width="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Настройки видны и редактируются только в Admin-режиме — обычный пользователь сюда не попадает."
                           TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,12" />

                <TextBlock Text="Путь клиентской сборки (ProfileRoot)" FontWeight="Bold" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ProfileRootTextBox" Grid.Column="0" Padding="4" Margin="0,0,8,0" />
                    <Button Grid.Column="1" Content="Обзор..." Padding="10,4" Click="BrowseProfileRoot_Click" />
                </Grid>
                <TextBlock Text="Ожидаемое имя папки сборки (для автопоиска)" Margin="0,4,0,4" />
                <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,4"
                           Text="Только ИМЯ папки (не путь), например VanillaScary — так называется папка инстанса в CurseForge/твоём лаунчере у КАЖДОГО игрока, независимо от диска и имени пользователя. Лаунчер ищет прямую подпапку с таким именем (без учёта регистра) в каждом из корней ниже по порядку — не рекурсивно, вложенные глубже подпапки не проверяются. Пусто — автопоиск клиента отключён, каждый игрок будет указывать путь вручную (кнопка «Обзор» в его окне)." />
                <TextBox x:Name="ClientFolderNameTextBox" Padding="4" Margin="0,0,0,4" />
                <TextBlock Text="Корни поиска клиента (по одному пути на строку; можно использовать переменные окружения, например %USERPROFILE%\curseforge\Instances — у каждого друга свой пользователь/диск)"
                           Margin="0,4,0,4" TextWrapping="Wrap" />
                <TextBox x:Name="ClientSearchRootsTextBox" Padding="4" Margin="0,0,0,4"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="50" />
                <Button Content="Найти автоматически" Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,16"
                        Click="AutoDetectClient_Click" />

                <TextBlock Text="Путь серверной директории (ServerDirectory)" FontWeight="Bold" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ServerDirectoryTextBox" Grid.Column="0" Padding="4" Margin="0,0,8,0" />
                    <Button Grid.Column="1" Content="Обзор..." Padding="10,4" Click="BrowseServerDirectory_Click" />
                </Grid>
                <TextBlock Text="Ожидаемое имя папки сервера (для автопоиска, рядом с .exe)" Margin="0,4,0,4" />
                <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,4"
                           Text="Только ИМЯ папки сервера (не путь) — актуально, если лаунчер лежит не прямо в папке сервера, а рядом с ней (например, обе — подпапки одной общей папки). Работает так же, как имя папки клиента выше: прямая подпапка, без учёта регистра, не рекурсивно. Папка рядом с самим exe проверяется всегда, даже если это поле пустое." />
                <TextBox x:Name="ServerFolderNameTextBox" Padding="4" Margin="0,0,0,4" />
                <TextBlock Text="Доп. корни поиска сервера (по одному пути на строку, тоже с поддержкой %VAR%; папка рядом с .exe проверяется всегда)" Margin="0,4,0,4" TextWrapping="Wrap" />
                <TextBox x:Name="ServerSearchRootsTextBox" Padding="4" Margin="0,0,0,4"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="50" />
                <Button Content="Найти автоматически" Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,16"
                        Click="AutoDetectServer_Click" />

                <TextBlock Text="Имя .bat-файла сервера (ServerBatFileName)" FontWeight="Bold" Margin="0,0,0,4" />
                <TextBox x:Name="ServerBatFileNameTextBox" Padding="4" Margin="0,0,0,16" />

                <TextBlock Text="ManifestUrl" FontWeight="Bold" Margin="0,0,0,4" />
                <TextBlock Text="Ссылка на manifest.json — список файлов сборки для клиента. Обычно не нужно вычислять вручную: если ниже задан репозиторий модпака (GitHubOwner/GitHubRepo) и хотя бы раз опубликовано обновление, подходит https://github.com/{Owner}/{Repo}/releases/latest/download/manifest.json — этот адрес всегда указывает на файл из САМОГО СВЕЖЕГО релиза."
                           Margin="0,0,0,4" TextWrapping="Wrap" Foreground="Gray" />
                <TextBox x:Name="ManifestUrlTextBox" Padding="4" Margin="0,0,0,16" />

                <TextBlock Text="Репозиторий МОДПАКА — куда публикуются моды/manifest.json (GitHubOwner / GitHubRepo)"
                           FontWeight="Bold" Margin="0,0,0,4" TextWrapping="Wrap" />
                <TextBlock Text="GitHubOwner — имя пользователя или организации на GitHub (например, Pewdoloco). GitHubRepo — имя конкретного репозитория внутри этого аккаунта (например, VanillaLauncher-localServer). Вместе они указывают на один репозиторий: github.com/{GitHubOwner}/{GitHubRepo}."
                           Margin="0,0,0,4" TextWrapping="Wrap" Foreground="Gray" />
                <TextBlock Text="GitHubOwner" Margin="0,0,0,4" />
                <TextBox x:Name="GitHubOwnerTextBox" Padding="4" Margin="0,0,0,8" />
                <TextBlock Text="GitHubRepo" Margin="0,0,0,4" />
                <TextBox x:Name="GitHubRepoTextBox" Padding="4" Margin="0,0,0,16" />

                <TextBlock Text="Репозиторий ДВИЖКА — откуда качать новую версию самого exe (EngineGitHubOwner / EngineGitHubRepo)"
                           FontWeight="Bold" Margin="0,0,0,4" TextWrapping="Wrap" />
                <TextBlock Text="Та же пара полей (Owner/Repo), но про ДРУГОЙ репозиторий: не тот, что публикует контент модпака выше, а репозиторий с исходным кодом самого лаунчера (обычно Pewdoloco / khanneli-local-launcher-minecraft). Используется только кнопкой «Проверить обновление лаунчера» в главном окне. Пусто = эта кнопка отключена, на остальной функционал не влияет."
                           Margin="0,0,0,4" TextWrapping="Wrap" Foreground="Gray" />
                <TextBlock Text="EngineGitHubOwner" Margin="0,0,0,4" />
                <TextBox x:Name="EngineGitHubOwnerTextBox" Padding="4" Margin="0,0,0,8" />
                <TextBlock Text="EngineGitHubRepo" Margin="0,0,0,4" />
                <TextBox x:Name="EngineGitHubRepoTextBox" Padding="4" Margin="0,0,0,16" />

                <TextBlock Text="IncludeFolders (по одной папке на строку)" FontWeight="Bold" Margin="0,0,0,4" />
                <TextBox x:Name="IncludeFoldersTextBox" Padding="4" Margin="0,0,0,16"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="60" />

                <TextBlock Text="ServerExcludeMods (по одному имени файла на строку)" FontWeight="Bold" Margin="0,0,0,4" />
                <TextBlock Text="Здесь только исключения — не полный список модов сборки, а лишь те, что НЕ должны попасть на сервер. Это и есть итоговый список исключений: его можно править прямо здесь текстом (дописать/удалить строку) в любой момент. Кнопка ниже — просто более удобный способ его заполнить: она сканирует папку с модами и позволяет отмечать файлы чекбоксами вместо ручного набора имён; результат сразу подставляется в это поле, ничего отдельно нажимать не нужно."
                           Margin="0,0,0,4" TextWrapping="Wrap" Foreground="Gray" />
                <TextBox x:Name="ServerExcludeModsTextBox" Padding="4" Margin="0,0,0,4"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="100"
                         VerticalScrollBarVisibility="Auto" />
                <Button Content="Выбрать моды из папки..." Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,16"
                        Click="PickExcludedMods_Click" />

                <TextBlock Text="MaxBackupsToKeep" FontWeight="Bold" Margin="0,0,0,4" />
                <TextBox x:Name="MaxBackupsToKeepTextBox" Padding="4" Margin="0,0,0,16" Width="80" HorizontalAlignment="Left" />

                <TextBlock Text="Руководства (показываются по кнопке «Инструкция» в окнах лаунчера)"
                           FontWeight="Bold" FontSize="14" Margin="0,8,0,4" />
                <TextBlock Text="Поля только для чтения, пока не нажата «Редактировать» — это защита от случайного
                           клика/ввода в текст руководства во время правки других настроек рядом. Во время
                           редактирования поле увеличивается для удобства печати, после «Готово» уменьшается обратно."
                           TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,8" />

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Клиент — краткое" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button x:Name="ClientGuideShortEditButton" Grid.Column="1" Content="Редактировать" Padding="10,4"
                            Click="ToggleGuideEdit_Click" Tag="ClientShort" />
                </Grid>
                <TextBox x:Name="ClientGuideShortTextBox" Padding="4" Margin="0,0,0,12" IsReadOnly="True"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="80" VerticalScrollBarVisibility="Auto" />

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Клиент — полное" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button x:Name="ClientGuideFullEditButton" Grid.Column="1" Content="Редактировать" Padding="10,4"
                            Click="ToggleGuideEdit_Click" Tag="ClientFull" />
                </Grid>
                <TextBox x:Name="ClientGuideFullTextBox" Padding="4" Margin="0,0,0,12" IsReadOnly="True"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="140" VerticalScrollBarVisibility="Auto" />

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Админ — краткое" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button x:Name="AdminGuideShortEditButton" Grid.Column="1" Content="Редактировать" Padding="10,4"
                            Click="ToggleGuideEdit_Click" Tag="AdminShort" />
                </Grid>
                <TextBox x:Name="AdminGuideShortTextBox" Padding="4" Margin="0,0,0,12" IsReadOnly="True"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="80" VerticalScrollBarVisibility="Auto" />

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Админ — полное" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button x:Name="AdminGuideFullEditButton" Grid.Column="1" Content="Редактировать" Padding="10,4"
                            Click="ToggleGuideEdit_Click" Tag="AdminFull" />
                </Grid>
                <TextBox x:Name="AdminGuideFullTextBox" Padding="4" Margin="0,0,0,16" IsReadOnly="True"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="140" VerticalScrollBarVisibility="Auto" />

                <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap"
                           Margin="0,8,0,0" Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Отмена" Padding="12,6" Margin="0,0,8,0" IsCancel="True" Click="CancelButton_Click" />
            <Button Content="Сохранить" Padding="12,6" IsDefault="True" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
