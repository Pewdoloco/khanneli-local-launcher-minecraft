<Window x:Class="VanillaLauncher.Client.UI.GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VanillaLauncher.Client.UI"
        mc:Ignorable="d"
        Title="Инструкция" Height="600" Width="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--
          Крупный, явно выделенный переключатель роли — чтобы не спутать, чью инструкцию
          читаешь. Из клиентского окна доступна только инструкция игрока (AdminRoleRadio
          скрывается в code-behind, см. конструктор) — Admin-инструкция про пароль/публикацию
          обычному игроку не нужна. Из Admin-окна доступны обе роли.
        -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Center">
            <RadioButton x:Name="ClientRoleRadio" GroupName="GuideRole" Margin="0,0,24,0"
                         Checked="RoleOrLength_Changed">
                <TextBlock Text="Пользователь" FontSize="20" FontWeight="Bold" />
            </RadioButton>
            <RadioButton x:Name="AdminRoleRadio" GroupName="GuideRole"
                         Checked="RoleOrLength_Changed">
                <TextBlock Text="Администратор" FontSize="20" FontWeight="Bold" />
            </RadioButton>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Center">
            <RadioButton x:Name="ShortRadio" Content="Краткое" GroupName="GuideLength" Margin="0,0,16,0"
                         IsChecked="True" Checked="RoleOrLength_Changed" />
            <RadioButton x:Name="FullRadio" Content="Полное" GroupName="GuideLength" Margin="0,0,16,0"
                         Checked="RoleOrLength_Changed" />
            <RadioButton x:Name="ManualRadio" Content="Пошаговое руководство" GroupName="GuideLength"
                         Checked="RoleOrLength_Changed" />
        </StackPanel>

        <TextBox x:Name="GuideTextBox" Grid.Row="2"
                 IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                 FontFamily="Consolas" Padding="8" Background="White" BorderThickness="1" />
    </Grid>
</Window>
