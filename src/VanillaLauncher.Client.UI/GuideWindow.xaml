<Window x:Class="VanillaLauncher.Client.UI.GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VanillaLauncher.Client.UI"
        mc:Ignorable="d"
        Title="Инструкция" Height="560" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="ShortRadio" Content="Краткое" GroupName="GuideLength" Margin="0,0,16,0"
                         IsChecked="True" Checked="ModeRadio_Checked" />
            <RadioButton x:Name="FullRadio" Content="Полное" GroupName="GuideLength"
                         Checked="ModeRadio_Checked" />
        </StackPanel>

        <TextBox x:Name="GuideTextBox" Grid.Row="1"
                 IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                 FontFamily="Consolas" Padding="8" Background="White" BorderThickness="1" />
    </Grid>
</Window>
