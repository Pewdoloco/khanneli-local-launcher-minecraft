<Window x:Class="VanillaLauncher.Client.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VanillaLauncher.Client.UI"
        mc:Ignorable="d"
        Title="VanillaLauncher" Height="480" Width="640"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText" Grid.Row="0" Text="Проверка манифеста..."
                   FontSize="16" Margin="0,0,0,8" TextWrapping="Wrap" />

        <ProgressBar x:Name="ProgressBar" Grid.Row="1" Height="20" Minimum="0" Maximum="100"
                     Visibility="Collapsed" Margin="0,0,0,8" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="CheckButton" Content="Проверить обновления" Padding="12,6" Margin="0,0,8,0"
                    Click="CheckButton_Click" />
            <Button x:Name="UpdateButton" Content="Обновить" Padding="12,6" IsEnabled="False"
                    Click="UpdateButton_Click" />
            <Button x:Name="GuideButton" Content="Инструкция" Padding="12,6" Margin="24,0,0,0"
                    Click="GuideButton_Click" />
            <Button x:Name="AdminButton" Content="Режим администратора" Padding="12,6" Margin="8,0,0,0"
                    Click="AdminButton_Click" />
            <Button x:Name="SelectProfileRootButton" Content="Сменить папку сборки" Padding="12,6"
                    Margin="8,0,0,0" Click="SelectProfileRootButton_Click" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="CheckEngineUpdateButton" Content="Проверить обновление лаунчера" Padding="12,6" Margin="0,0,8,0"
                    Click="CheckEngineUpdateButton_Click" />
            <Button x:Name="UpdateEngineButton" Content="Обновить лаунчер" Padding="12,6" IsEnabled="False"
                    Click="UpdateEngineButton_Click" />
            <TextBlock x:Name="EngineStatusText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap" Foreground="Gray" />
        </StackPanel>

        <TextBlock Grid.Row="4" Text="Журнал:" FontWeight="Bold" Margin="0,0,0,4" />

        <ListBox x:Name="LogList" Grid.Row="5" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
