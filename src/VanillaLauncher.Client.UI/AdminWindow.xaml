<Window x:Class="VanillaLauncher.Client.UI.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VanillaLauncher.Client.UI"
        mc:Ignorable="d"
        Title="VanillaLauncher — Admin" Height="580" Width="720"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText" Grid.Row="0" Text="Сервер остановлен."
                   FontSize="16" Margin="0,0,0,8" TextWrapping="Wrap" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="StartButton" Content="Запустить сервер" Padding="12,6" Margin="0,0,8,0"
                    Click="StartButton_Click" />
            <Button x:Name="StopButton" Content="Остановить сервер" Padding="12,6" IsEnabled="False"
                    Click="StopButton_Click" />
            <Button x:Name="SelectServerDirectoryButton" Content="Выбрать папку сервера" Padding="12,6"
                    Margin="8,0,0,0" Visibility="Collapsed" Click="SelectServerDirectoryButton_Click" />
            <Button x:Name="SettingsButton" Content="Настройки" Padding="12,6" Margin="24,0,0,0"
                    Click="SettingsButton_Click" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="RecreateWorldButton" Content="Пересоздать мир (с бэкапом)" Padding="12,6"
                    Click="RecreateWorldButton_Click" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Версия релиза:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="VersionTextBox" Width="160" VerticalContentAlignment="Center" Margin="0,0,8,0" />
            <Button x:Name="PublishButton" Content="Опубликовать обновление" Padding="12,6"
                    Click="PublishButton_Click" />
        </StackPanel>

        <TextBlock Grid.Row="4" Text="Консоль сервера:" FontWeight="Bold" Margin="0,0,0,4" />

        <ListBox x:Name="LogList" Grid.Row="5" FontFamily="Consolas" />
    </Grid>
</Window>
