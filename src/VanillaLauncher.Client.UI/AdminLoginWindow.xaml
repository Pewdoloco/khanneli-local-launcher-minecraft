<Window x:Class="VanillaLauncher.Client.UI.AdminLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VanillaLauncher.Client.UI"
        mc:Ignorable="d"
        Title="Вход в режим администратора" Height="200" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Пароль:" Margin="0,0,0,4" />
        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8" Padding="4" />

        <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap"
                   Margin="0,0,0,8" Visibility="Collapsed" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Padding="12,6" Margin="0,0,8,0" IsCancel="True" Click="CancelButton_Click" />
            <Button Content="Войти" Padding="12,6" IsDefault="True" Click="LoginButton_Click" />
        </StackPanel>
    </StackPanel>
</Window>
